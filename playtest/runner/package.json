{
  "name": "copa-agent-runner",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "agent": "ts-node src/cli.ts",
    "agent:build": "tsc",
    "agent:run": "node dist/cli.js",
    "test": "playwright test tests/",
    "test:ci": "playwright test tests/critical-flow.test.ts tests/run-lifecycle.test.ts tests/player-profile-ui.test.ts --project=mobile-chromium --project=desktop-chromium",
    "test:cross": "playwright test tests/cross-browser-smoke.test.ts",
    "test:bridge": "playwright test tests/bridge.test.ts",
    "test:session": "playwright test tests/session.test.ts",
    "assets:store": "node capture-store-assets.mjs"
  },
  "dependencies": {
    "@playwright/test": "^1.44.0",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
