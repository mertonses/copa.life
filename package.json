{
  "name": "copa-life",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "postinstall": "node tools/patch-capacitor-safe-area.mjs",
    "brand:assets": "node tools/apply-brand-palette.mjs && node tools/generate-favicons.mjs favicon.svg && node tools/generate-ios-assets.mjs && node tools/generate-android-assets.mjs",
    "favicons": "node tools/generate-favicons.mjs favicon.svg",
    "fix:encoding": "node tools/fix-mojibake.mjs",
    "build:pages": "node tools/build-pages.mjs",
    "build:legal": "node tools/build-legal-pages.mjs",
    "check:legal": "npm run build:legal && node tools/check-legal-pages.mjs",
    "build:android": "node tools/build-android.mjs",
    "check:parity": "npm run build:pages && npm run build:android && npm run build:ios && node tools/check-platform-parity.mjs && npm run check:android && npm run check:ios",
    "assets:store": "npm run build:android && npm run assets:store --prefix playtest/runner",
    "assets:store:feature": "npm run assets:feature --prefix playtest/runner",
    "assets:store:video": "npm run assets:promo-video --prefix playtest/runner",
    "android:add": "npm run build:android && node tools/capacitor-platform.mjs android add",
    "android:sync": "npm run build:android && npm run check:android && node tools/capacitor-platform.mjs android sync",
    "android:open": "node tools/capacitor-platform.mjs android open",
    "android:version": "node tools/android-version.mjs show",
    "android:version:check": "node tools/android-version.mjs check",
    "android:version:patch": "node tools/android-version.mjs bump patch",
    "android:version:minor": "node tools/android-version.mjs bump minor",
    "android:version:major": "node tools/android-version.mjs bump major",
    "android:notes:stamp": "node tools/android-release-notes.mjs stamp",
    "android:doctor": "node tools/android-doctor.mjs",
    "android:physical-gate": "powershell -ExecutionPolicy Bypass -File tools/android-physical-gate.ps1",
    "android:candidate:local": "powershell -ExecutionPolicy Bypass -File tools/build-android-release.ps1 -AllowDirty",
    "android:release:local": "powershell -ExecutionPolicy Bypass -File tools/build-android-release.ps1",
    "check:android": "node tools/check-android-package.mjs",
    "check:android:store": "node tools/check-android-store-assets.mjs",
    "check:android:release": "node tools/check-android-release.mjs",
    "check:android:aab": "node tools/run-java.mjs tools/CheckAndroidAab.java android/app/build/outputs/bundle/release/app-release.aab",
    "check:android:signature": "node tools/check-android-signature.mjs android/app/build/outputs/bundle/release/app-release-signed.aab",
    "build:ios": "node tools/build-ios.mjs",
    "check:ios": "node tools/check-ios-package.mjs",
    "check:ios:readiness": "node tools/check-ios-readiness.mjs",
    "ios:add": "npm run build:ios && node tools/capacitor-platform.mjs ios add",
    "ios:sync": "npm run build:ios && npm run check:ios && node tools/capacitor-platform.mjs ios sync",
    "ios:open": "node tools/capacitor-platform.mjs ios open",
    "ios:doctor": "node tools/ios-doctor.mjs",
    "ios:simulator": "bash tools/build-ios-simulator.sh",
    "ios:archive": "bash tools/archive-ios-release.sh",
    "ios:version": "node tools/ios-version.mjs show",
    "ios:version:patch": "node tools/ios-version.mjs bump patch",
    "ios:version:minor": "node tools/ios-version.mjs bump minor",
    "ios:version:major": "node tools/ios-version.mjs bump major",
    "audit:security": "npm audit --audit-level=high && npm audit --audit-level=high --prefix services/ghost-club-api && npm audit --audit-level=high --prefix playtest/runner",
    "check:encoding": "node tools/check-encoding.mjs",
    "check:locales": "node tools/check-locales.mjs",
    "check:responsive": "node tools/check-responsive.mjs",
    "check:faq": "node tools/check-faq.mjs",
    "check:story-icons": "node tools/check-story-icons.mjs",
    "check:palette": "node tools/check-color-palette.mjs",
    "check:cards": "node tools/check-card-copy.mjs",
    "check:positions": "node tools/check-position-fit.mjs",
    "players:rebalance": "node tools/rebalance-player-pools.mjs --write",
    "check:playerbalance": "node tools/check-player-balance.mjs",
    "check:draftquality": "node tools/check-draft-quality.mjs",
    "check:finalsim": "node tools/check-final-sim.mjs",
    "check:finalsim:stats": "node tools/final-sim-quality-report.mjs --check",
    "check:finalsim:ab": "node tools/final-sim-ab-report.mjs --check",
    "check:normalmatch": "node tools/check-normal-match-balance.mjs",
    "check:performance": "node tools/check-performance.mjs",
    "check:deploy": "node tools/check-deploy-package.mjs",
    "check:cardbalance": "node tools/card-economy-audit.mjs --check",
    "check:freeagents": "node tools/check-free-agent-pricing.mjs",
    "check:economy": "node tools/check-economy-balance.mjs",
    "check:chairmen": "node tools/check-chairman-events.mjs",
    "check:trust": "node tools/check-chairman-trust-info.mjs",
    "check:meta": "node tools/check-meta-progression.mjs",
    "check:lineupsync": "node tools/check-lineup-power-sync.mjs",
    "check:clubnames": "node tools/check-club-name-security.mjs",
    "check:ghosts": "node tools/check-ghost-clubs.mjs",
    "check:analytics": "npm run build:pages && npm run build:android && npm run build:ios && node tools/check-analytics.mjs",
    "analytics:report": "node services/ghost-club-api/scripts/analytics-report.mjs",
    "analytics:monitor": "node services/ghost-club-api/scripts/analytics-monitor.mjs",
    "check:rights": "node tools/check-publishing-rights.mjs",
    "check:rights:public": "node tools/check-publishing-rights.mjs --public",
    "test:worker": "npm test --prefix services/ghost-club-api",
    "report:cards": "node tools/card-balance-report.mjs",
    "profiles:manifest": "node tools/export-player-profile-manifest.mjs",
    "profiles:build-copa": "node tools/build-copa-player-profiles.mjs",
    "check:profiles": "node tools/check-player-profiles.mjs",
    "check:lastmatch": "node tools/check-last-match-report.mjs",
    "check:scout": "node tools/check-scout-report.mjs",
    "check:japan": "node tools/check-japan-country.mjs",
    "audit:japan-data": "node tools/audit-japan-player-data.mjs",
    "check:persistence": "node tools/check-run-persistence.mjs",
    "check:mobile-readiness": "node tools/check-mobile-readiness.mjs",
    "check:tournament": "node tools/check-group-tournament.mjs",
    "check:tournament:balance": "node tools/check-tournament-balance.mjs",
    "check:tournament:balance:matrix": "node tools/check-tournament-balance-matrix.mjs",
    "test": "npm run check:encoding && npm run check:locales && npm run check:responsive && npm run check:faq && npm run check:story-icons && npm run check:palette && npm run check:cards && npm run check:positions && npm run check:playerbalance && npm run check:draftquality && npm run check:profiles && npm run check:lastmatch && npm run check:scout && npm run check:japan && npm run audit:japan-data && npm run check:persistence && npm run check:mobile-readiness && npm run check:tournament && npm run check:tournament:balance && npm run check:tournament:balance:matrix && npm run check:finalsim && npm run check:finalsim:stats && npm run check:finalsim:ab && npm run check:normalmatch && npm run check:cardbalance && npm run check:freeagents && npm run check:economy && npm run check:chairmen && npm run check:trust && npm run check:meta && npm run check:lineupsync && npm run check:clubnames && npm run check:ghosts && npm run check:analytics && npm run check:rights && npm run check:performance && npm run check:deploy && npm run check:legal && npm run check:android:store && npm run check:android:release && npm run check:ios:readiness"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/cli": "8.4.2",
    "@capacitor/ios": "8.4.2",
    "ffmpeg-static": "^5.3.0"
  },
  "dependencies": {
    "@capacitor/app": "8.1.1",
    "@capacitor/browser": "8.0.4",
    "@capacitor/core": "8.4.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/splash-screen": "8.0.2",
    "@capacitor/status-bar": "8.0.3"
  }
}
