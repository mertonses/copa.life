{
  "name": "copa-life",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "favicons": "node tools/generate-favicons.mjs favicon.svg",
    "fix:encoding": "node tools/fix-mojibake.mjs",
    "build:pages": "node tools/build-pages.mjs",
    "build:legal": "node tools/build-legal-pages.mjs",
    "check:legal": "npm run build:legal && node tools/check-legal-pages.mjs",
    "build:android": "node tools/build-android.mjs",
    "check:parity": "npm run build:pages && npm run build:android && node tools/check-platform-parity.mjs && npm run check:android",
    "assets:store": "npm run build:android && npm run assets:store --prefix playtest/runner",
    "android:add": "npm run build:android && npx cap add android",
    "android:sync": "npm run build:android && npm run check:android && npx cap sync android",
    "android:open": "npx cap open android",
    "android:version": "node tools/android-version.mjs show",
    "android:version:check": "node tools/android-version.mjs check",
    "android:version:patch": "node tools/android-version.mjs bump patch",
    "android:version:minor": "node tools/android-version.mjs bump minor",
    "android:version:major": "node tools/android-version.mjs bump major",
    "android:notes:stamp": "node tools/android-release-notes.mjs stamp",
    "android:doctor": "node tools/android-doctor.mjs",
    "android:candidate:local": "powershell -ExecutionPolicy Bypass -File tools/build-android-release.ps1 -AllowDirty",
    "android:release:local": "powershell -ExecutionPolicy Bypass -File tools/build-android-release.ps1",
    "check:android": "node tools/check-android-package.mjs",
    "check:android:release": "node tools/check-android-release.mjs",
    "check:android:aab": "node tools/run-java.mjs tools/CheckAndroidAab.java android/app/build/outputs/bundle/release/app-release.aab",
    "check:android:signature": "node tools/check-android-signature.mjs android/app/build/outputs/bundle/release/app-release-signed.aab",
    "audit:security": "npm audit --audit-level=high && npm audit --audit-level=high --prefix services/ghost-club-api && npm audit --audit-level=high --prefix playtest/runner",
    "check:encoding": "node tools/check-encoding.mjs",
    "check:locales": "node tools/check-locales.mjs",
    "check:responsive": "node tools/check-responsive.mjs",
    "check:cards": "node tools/check-card-copy.mjs",
    "check:positions": "node tools/check-position-fit.mjs",
    "check:draftquality": "node tools/check-draft-quality.mjs",
    "check:finalsim": "node tools/check-final-sim.mjs",
    "check:finalsim:stats": "node tools/final-sim-quality-report.mjs --check",
    "check:performance": "node tools/check-performance.mjs",
    "check:deploy": "node tools/check-deploy-package.mjs",
    "check:cardbalance": "node tools/card-economy-audit.mjs --check",
    "check:economy": "node tools/check-economy-balance.mjs",
    "check:chairmen": "node tools/check-chairman-events.mjs",
    "check:trust": "node tools/check-chairman-trust-info.mjs",
    "check:lineupsync": "node tools/check-lineup-power-sync.mjs",
    "check:clubnames": "node tools/check-club-name-security.mjs",
    "check:ghosts": "node tools/check-ghost-clubs.mjs",
    "check:analytics": "npm run build:pages && npm run build:android && node tools/check-analytics.mjs",
    "analytics:report": "node services/ghost-club-api/scripts/analytics-report.mjs",
    "analytics:monitor": "node services/ghost-club-api/scripts/analytics-monitor.mjs",
    "check:rights": "node tools/check-publishing-rights.mjs",
    "check:rights:public": "node tools/check-publishing-rights.mjs --public",
    "test:worker": "npm test --prefix services/ghost-club-api",
    "report:cards": "node tools/card-balance-report.mjs",
    "profiles:manifest": "node tools/export-player-profile-manifest.mjs",
    "profiles:build-copa": "node tools/build-copa-player-profiles.mjs",
    "check:profiles": "node tools/check-player-profiles.mjs",
    "check:lastmatch": "node tools/check-last-match-report.mjs",
    "check:scout": "node tools/check-scout-report.mjs",
    "check:japan": "node tools/check-japan-country.mjs",
    "audit:japan-data": "node tools/audit-japan-player-data.mjs",
    "check:persistence": "node tools/check-run-persistence.mjs",
    "test": "npm run check:encoding && npm run check:locales && npm run check:responsive && npm run check:cards && npm run check:positions && npm run check:draftquality && npm run check:profiles && npm run check:lastmatch && npm run check:scout && npm run check:japan && npm run audit:japan-data && npm run check:persistence && npm run check:finalsim && npm run check:finalsim:stats && npm run check:cardbalance && npm run check:economy && npm run check:chairmen && npm run check:trust && npm run check:lineupsync && npm run check:clubnames && npm run check:ghosts && npm run check:analytics && npm run check:rights && npm run check:performance && npm run check:deploy && npm run check:legal && npm run check:android:release"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "ffmpeg-static": "^5.3.0"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3"
  }
}
