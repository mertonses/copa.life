{
  "appId": "life.copa.app",
  "appName": "Copa Life",
  "webDir": "dist-android",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#f5f0e8",
    "allowMixedContent": false
  },
  "ios": {
    "backgroundColor": "#f5f0e8",
    "contentInset": "never",
    "zoomEnabled": false,
    "allowsLinkPreview": false,
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "SystemBars": {
      "insetsHandling": "css",
      "style": "LIGHT",
      "hidden": false
    },
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#f5f0e8",
      "showSpinner": false,
      "launchFadeOutDuration": 220
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#f5f0e8",
      "overlaysWebView": false
    }
  }
}
